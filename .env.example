# API (backend) — Python server listens on 8000 by default (see backend/server/app.py)
PORT=8000

# Web (frontend) — leave unset in dev to use Vite’s /api proxy; or set full API origin
# VITE_API_URL=http://localhost:8000

# Google AI — required by the Gemini vision agent
# Get a key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here
