# MongoDB Atlas connection string — required by the session store
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Clerk backend secret for verifying frontend session tokens
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# Allowed frontend origins for Clerk token verification
# Comma-separate multiple origins if needed.
CLERK_AUTHORIZED_PARTIES=http://localhost:5173

# Google AI Studio key — required by the Gemini agent
# Get a key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Optional: override the API origin the frontend talks to.
# In development the Vite proxy handles this automatically (no value needed).
# In production, set this to the backend’s public URL (no trailing slash).
# VITE_API_URL=https://your-backend.example.com

# Clerk publishable key for the Vue frontend
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here
